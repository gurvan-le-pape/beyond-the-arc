{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "prestart:dev": "npm run prisma:generate",
    "start:dev": "nest start --watch --ts-config tsconfig.build.json",
    "poststart:dev": "find dist -type f -name '*.spec.js' -exec rm -f {} + 2>/dev/null || true",
    "clean:specs": "find dist -name '*.spec.js' -type f -delete 2>/dev/null || true",
    "start": "nest start --ts-config tsconfig.json",
    "build": "nest build -p tsconfig.build.json && npm run clean:specs",
    "test": "jest",
    "lint": "eslint '**/*.ts'",
    "format": "prettier --write .",
    "db:migrate": "ts-node -r tsconfig-paths/register migrations/run-migrations.ts",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate-deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:migrate-dev": "prisma migrate dev --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.9",
    "@nestjs/core": "^11.0.9",
    "@nestjs/platform-express": "^11.0.9",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/client": "^6.1.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "^5.2.1",
    "pg": "^8.10.0",
    "prisma": "^6.1.0",
    "rxjs": "^7.0.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/testing": "^11.1.12",
    "@types/cache-manager": "^5.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "barrelsby": "^2.8.1",
    "eslint": "^9.20.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "jest": "^29.7.0",
    "prettier": "^2.5.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
